Options -Indexes
RewriteEngine On

# Redirigir URLs viejas de Jimdo a la web nueva
# Usar RewriteRule con comodin para manejar caracteres especiales (á, é, etc.)
RewriteRule ^cont.ctenos/?$ https://www.dulikosrl.com/ [R=301,L,NC]
RewriteRule ^contactenos/?$ https://www.dulikosrl.com/ [R=301,L,NC]
RewriteRule ^sitemap/?$ https://www.dulikosrl.com/sitemap.xml [R=301,L,NC]
RewriteRule ^sobre-nosotros/?$ https://www.dulikosrl.com/ [R=301,L,NC]
RewriteRule ^productos/?$ https://www.dulikosrl.com/productos.html [R=301,L,NC]
RewriteRule ^inicio/?$ https://www.dulikosrl.com/ [R=301,L,NC]
